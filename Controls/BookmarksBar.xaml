<UserControl x:Class="QuickSurfBrowser.Controls.BookmarksBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <UserControl.Resources>
        <Style x:Key="BookmarkButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2,0,2,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTipService.ShowDuration" Value="3000"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Border Background="White" BorderBrush="#E5E0D8" BorderThickness="0,1" Height="36">
        <DockPanel Margin="8,0,8,0">
            <TextBlock DockPanel.Dock="Left" Text="★" FontSize="18" VerticalAlignment="Center" 
                       Foreground="#FF8C42" Margin="0,0,8,0" Cursor="Hand" 
                       ToolTip="Добавить текущую страницу в избранное"
                       MouseLeftButtonUp="AddCurrentPage_Click"/>
            
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="BookmarksPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
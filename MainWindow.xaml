<Window x:Class="QuickSurfBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="QuickSurf" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FAF7F2">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <StackPanel Grid.Row="0" Background="#FAF7F2" Margin="12,12,12,6">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="◀" Width="40" Height="40" Margin="0,0,8,0" 
                        Background="White" BorderBrush="#E5E0D8" BorderThickness="1"
                        Click="BtnBack_Click" Cursor="Hand"/>
                <Button Content="▶" Width="40" Height="40" Margin="0,0,8,0" 
                        Background="White" BorderBrush="#E5E0D8" BorderThickness="1"
                        Click="BtnForward_Click" Cursor="Hand"/>
                <Button Content="↻" Width="40" Height="40" Margin="0,0,8,0" 
                        Background="White" BorderBrush="#E5E0D8" BorderThickness="1"
                        Click="BtnRefresh_Click" Cursor="Hand"/>
                
                <TextBox x:Name="UrlBox" Width="600" Height="40" Margin="0,0,12,0"
                         Background="White" BorderBrush="#E5E0D8" BorderThickness="1"
                         VerticalContentAlignment="Center" Padding="15,0" FontSize="14"
                         KeyDown="UrlBox_KeyDown"/>
                
                <Button Content="Go" Width="60" Height="40" Margin="0,0,10,0"
                        Background="#FF8C42" Foreground="White" BorderThickness="0"
                        Click="BtnGo_Click" Cursor="Hand"/>

                <Button Content="+" Width="40" Height="40"
                        Background="#4ECDC4" Foreground="White" BorderThickness="0" FontSize="22"
                        Click="BtnNewTab_Click" Cursor="Hand" ToolTip="Новая вкладка"/>
                
                <Button Content="🕒" Width="40" Height="40" Margin="8,0,0,0"
                        Background="White" BorderBrush="#E5E0D8" BorderThickness="1"
                        Click="BtnToggleHistory_Click" Cursor="Hand" ToolTip="История"/>
            </StackPanel>

            <TabControl x:Name="TabsControl" BorderThickness="0" Background="Transparent"
                        SelectionChanged="TabsControl_SelectionChanged">
            </TabControl>
        </StackPanel>

        <!-- ОСНОВНАЯ ОБЛАСТЬ С ИСТОРИЕЙ -->
        <Grid Grid.Row="1" Margin="12,0,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0"/> <!-- Скрыта по умолчанию -->
            </Grid.ColumnDefinitions>
            
            <!-- БРАУЗЕР -->
            <Border Grid.Column="0" Background="White" 
                    BorderBrush="#E5E0D8" BorderThickness="1">
                <wv2:WebView2 x:Name="WebView" DefaultBackgroundColor="White"/>
            </Border>

            <!-- ПАНЕЛЬ ИСТОРИИ -->
            <Border x:Name="HistoryPanel" Grid.Column="1" Width="320" Background="#FAF7F2"
                    BorderBrush="#E5E0D8" BorderThickness="1,0,0,0" Visibility="Collapsed">
                <DockPanel Margin="12">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBox x:Name="HistorySearchBox" Width="200" Height="32"
                                 Background="White" BorderBrush="#E5E0D8" BorderThickness="1"
                                 VerticalContentAlignment="Center" Padding="10,0" FontSize="13"
                                 TextChanged="HistorySearchBox_TextChanged"/>
                        <Button Content="🗑️" Width="32" Height="32" Margin="8,0,0,0"
                                Background="White" BorderBrush="#E5E0D8" BorderThickness="1"
                                Click="BtnClearHistory_Click" Cursor="Hand" ToolTip="Очистить"/>
                    </StackPanel>
                    <ListBox x:Name="HistoryList" Background="Transparent" BorderThickness="0"
                             SelectionMode="Single" MouseDoubleClick="HistoryList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,6">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" Foreground="#4A4A4A" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Url}" FontSize="11" Foreground="#888888" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Time, StringFormat=dd.MM.yy HH:mm}" FontSize="10" Foreground="#AAAAAA" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
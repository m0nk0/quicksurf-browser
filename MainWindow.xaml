<Window x:Class="QuickSurfBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:models="clr-namespace:QuickSurfBrowser.Models"
        Title="QuickSurf" 
        Height="700" 
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="White"
        Icon="Assets/logo.ico"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">
    
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF8C42"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4ECDC4"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E0D8"/>
        
        <ContextMenu x:Key="MainContextMenu">
            <MenuItem Header=" Назад" Click="CtxBack_Click"/>
            <MenuItem Header=" Вперед" Click="CtxForward_Click"/>
            <MenuItem Header=" Обновить" Click="CtxRefresh_Click"/>
            <Separator/>
            <MenuItem Header="🤖 AI: Перевести выделенное" Click="CtxAITranslate_Click"/>
            <MenuItem Header="🤖 AI: Объяснить выделенное" Click="CtxAIExplain_Click"/>
            <MenuItem Header="🤖 AI: Суммаризировать страницу" Click="CtxAISummarize_Click"/>
            <MenuItem Header="🤖 AI: Найти ошибки в коде" Click="CtxAICheckCode_Click"/>
            <Separator/>
            <MenuItem Header="📋 Копировать" Click="CtxCopy_Click"/>
            <MenuItem Header="🔍 Искать в Google" Click="CtxSearch_Click"/>
        </ContextMenu>

        <!-- Стили кнопок и элементов -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="UrlTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFE8D6"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Background="White" Margin="12,12,12,6">
            <!-- Кнопки навигации и адресная строка -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="🏠" Style="{StaticResource NavButtonStyle}" Click="BtnHome_Click" ToolTip="На стартовую"/>
                <Button Content="◀" Style="{StaticResource NavButtonStyle}" Click="BtnBack_Click" ToolTip="Назад"/>
                <Button Content="▶" Style="{StaticResource NavButtonStyle}" Click="BtnForward_Click" ToolTip="Вперед"/>
                <Button Content="↻" Style="{StaticResource NavButtonStyle}" Click="BtnRefresh_Click" ToolTip="Обновить"/>
                
                <TextBox x:Name="UrlBox" 
                         Style="{StaticResource UrlTextBoxStyle}" 
                         Width="600"
                         KeyDown="UrlBox_KeyDown"
                         PreviewMouseLeftButtonDown="UrlBox_PreviewMouseLeftButtonDown"
                         GotFocus="UrlBox_GotFocus"
                         Margin="0,0,12,0"/>
                
                <Button Content="Go" 
                        Width="60" 
                        Height="40" 
                        Margin="0,0,10,0" 
                        Background="{StaticResource PrimaryBrush}" 
                        Foreground="White" 
                        BorderThickness="0" 
                        FontSize="14" 
                        FontWeight="SemiBold" 
                        Click="BtnGo_Click" 
                        Cursor="Hand"/>
                
                <Button Content="🤖" 
                        Width="40" 
                        Height="40" 
                        Margin="8,0,0,0" 
                        Background="White" 
                        BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="1" 
                        Click="BtnToggleAI_Click" 
                        Cursor="Hand" 
                        ToolTip="Открыть AI панель"/>
                
                <Button Content="🕒" 
                        Width="40" 
                        Height="40" 
                        Margin="8,0,0,0" 
                        Background="White" 
                        BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="1" 
                        Click="BtnToggleHistory_Click" 
                        Cursor="Hand" 
                        ToolTip="История"/>
            </StackPanel>

            <!-- Панель вкладок -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="White" Padding="4,0,4,0">
                    <ItemsControl ItemsSource="{Binding TabsCollection}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:TabItemModel}">
                                <Border x:Name="TabBorder"
                                        Background="Transparent"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6,6,0,0"
                                        Padding="10,5"
                                        Margin="0,0,4,0"
                                        Width="160"
                                        Height="32"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="Tab_Click"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="13"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,6,0"/>
                                        <Button Grid.Column="1"
                                                Content="✕"
                                                Style="{StaticResource TabCloseButtonStyle}"
                                                Click="Tab_CloseClick"
                                                Tag="{Binding}"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="White"/>
                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,1,1,0"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#FFE8D6"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
                
              <StackPanel Grid.Column="1" Orientation="Horizontal">
    <Button Content="+"
    Width="32"
    Height="32"
    Margin="0,0,4,0"
    Background="{StaticResource AccentBrush}"
    Foreground="White"
    BorderThickness="0"
    FontSize="20"
    FontWeight="Bold"
    Cursor="Hand"
    Click="BtnCreateTab_Click"
    ToolTip="Новая вкладка (Ctrl+T)"/>
    <Button Content="⊞"
    Width="32"
    Height="32"
    Margin="0"
    Background="#E5E0D8"
    Foreground="#4A4A4A"
    BorderThickness="0"
    FontSize="16"
    FontWeight="Bold"
    Cursor="Hand"
    Click="BtnCloseOtherTabs_Click"
    ToolTip="Закрыть все, кроме текущей"/>
</StackPanel>
            </Grid>
        </StackPanel>

        <!-- WebView2 (браузер) -->
        <Border Grid.Row="1" Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <wv2:WebView2 x:Name="WebView" 
              DefaultBackgroundColor="White"/>
        </Border>

        <!-- Панель истории -->
        <Border x:Name="HistoryPanel" 
                Grid.Row="1" 
                Grid.Column="1" 
                Width="400" 
                Background="White" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1,0,0,0" 
                Visibility="Collapsed" 
                Panel.ZIndex="11">
            <DockPanel Margin="12">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <TextBox x:Name="HistorySearchBox" 
                                 Width="200" 
                                 Height="32" 
                                 Background="White" 
                                 BorderBrush="{StaticResource BorderBrush}" 
                                 BorderThickness="1" 
                                 VerticalContentAlignment="Center" 
                                 Padding="10,0" 
                                 FontSize="13" 
                                 TextChanged="HistorySearchBox_TextChanged"/>
                        <Button x:Name="BtnClearHistory" 
                                Content="🗑️" 
                                Width="32" 
                                Height="32" 
                                Margin="8,0,0,0" 
                                Background="White" 
                                BorderBrush="{StaticResource BorderBrush}" 
                                BorderThickness="1" 
                                Click="BtnClearHistory_Click" 
                                Cursor="Hand" 
                                ToolTip="Очистить историю"/>
                    </StackPanel>
                    <Button Content="✕" 
                            Grid.Column="1" 
                            HorizontalAlignment="Right" 
                            Width="28" 
                            Height="28" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Cursor="Hand" 
                            Click="BtnCloseHistory_Click" 
                            FontSize="14" 
                            Foreground="#888" 
                            ToolTip="Закрыть историю"/>
                </Grid>
                <ListBox x:Name="HistoryList" 
                         Background="Transparent" 
                         BorderThickness="0" 
                         SelectionMode="Single" 
                         MouseDoubleClick="HistoryList_MouseDoubleClick" 
                         VirtualizingPanel.IsVirtualizing="True" 
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,6">
                                <TextBlock Text="{Binding Title}" 
                                           FontWeight="SemiBold" 
                                           FontSize="13" 
                                           Foreground="#4A4A4A" 
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Url}" 
                                           FontSize="11" 
                                           Foreground="#888888" 
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Time, StringFormat=dd.MM.yy HH:mm}" 
                                           FontSize="10" 
                                           Foreground="#AAAAAA" 
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- AI Sidebar -->
        <Border x:Name="AISidebar" 
                Grid.Row="1" 
                Grid.Column="1" 
                Width="400" 
                Background="White" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1,0,0,0" 
                Visibility="Collapsed" 
                Panel.ZIndex="11">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="White" Padding="15">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🤖 AI Assistant" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center" 
                                   Foreground="#4A4A4A"/>
                        <Button Content="✕" 
                                Width="28" 
                                Height="28" 
                                Margin="10,0,0,0" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Cursor="Hand" 
                                Click="BtnCloseSidebar_Click" 
                                FontSize="14" 
                                Foreground="#888"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Row="1" Background="White" Padding="15" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
                    <StackPanel>
                        <TextBlock Text="Выберите ИИ:" FontSize="12" Foreground="#888" Margin="0,0,0,5"/>
                        <ComboBox x:Name="AIProviderComboBox" Height="32" FontSize="13" Margin="0,0,0,8">
                            <ComboBoxItem Content="🤖 Алиса (Яндекс)" IsSelected="True"/>
                            <ComboBoxItem Content="🤖 ChatGPT"/>
                            <ComboBoxItem Content="🤖 DeepSeek"/>
                        </ComboBox>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Сохранить" 
                                    Width="85" 
                                    Height="26" 
                                    FontSize="11" 
                                    Click="BtnSaveContext_Click" 
                                    Background="White" 
                                    BorderBrush="{StaticResource BorderBrush}" 
                                    Cursor="Hand"/>
                            <Button Content="🗑️ Очистить" 
                                    Width="85" 
                                    Height="26" 
                                    FontSize="11" 
                                    Click="BtnClearContext_Click" 
                                    Margin="5,0,0,0" 
                                    Background="White" 
                                    BorderBrush="{StaticResource BorderBrush}" 
                                    Cursor="Hand"/>
                            <TextBlock x:Name="ContextStatusText" 
                                       Text="Контекст: 0" 
                                       FontSize="10" 
                                       Foreground="#888" 
                                       VerticalAlignment="Center" 
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <ScrollViewer x:Name="ChatScrollViewer" 
                              Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,10">
                    <StackPanel x:Name="ChatMessages" Margin="15,0"/>
                </ScrollViewer>
                
                <Border Grid.Row="3" Background="White" Padding="15" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ChatInput"
                                 Height="80"
                                 FontSize="16"
                                 VerticalContentAlignment="Top"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Padding="15,8"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 KeyDown="ChatInput_KeyDown"/>
                        <Button Content="➤" 
                                Grid.Column="1" 
                                Width="40" 
                                Height="80" 
                                Margin="8,0,0,0" 
                                Background="{StaticResource PrimaryBrush}" 
                                Foreground="White" 
                                BorderThickness="0" 
                                FontSize="18" 
                                Cursor="Hand" 
                                Click="BtnSendChat_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- СТАРТОВАЯ СТРАНИЦА -->
        <Grid x:Name="StartPageContainer" 
              Grid.Row="1" 
              Grid.ColumnSpan="2" 
              Background="White" 
              Visibility="Visible" 
              Panel.ZIndex="10">
            
            <!-- Шапка стартовой страницы -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,25,0,0">
                <Image Source="Assets/logo.png" Width="44" Height="44" Margin="0,0,15,0"/>
                <TextBlock Text="QuickSurf" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="#4A4A4A" 
                           VerticalAlignment="Center" 
                           Margin="0,0,50,0"/>
                <Border Height="24" Width="1" Background="#E5E0D8" Margin="0,0,30,0" VerticalAlignment="Center"/>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Добавить ресурс" 
                               FontSize="15" 
                               VerticalAlignment="Center" 
                               Foreground="#888888" 
                               Margin="0,0,12,0"/>
                    <Button Content="+" 
                            Width="32" 
                            Height="32" 
                            Background="{StaticResource AccentBrush}" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="16" 
                            FontWeight="Bold" 
                            Cursor="Hand" 
                            Click="BtnAddTile_Click" 
                            ToolTip="Добавить новый сайт" 
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF8C42"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <StackPanel x:Name="AddTileForm" Orientation="Horizontal" Visibility="Collapsed" Margin="12,0,0,0">
                        <TextBox x:Name="NewTileTitle" 
                                 Width="110" 
                                 Height="30" 
                                 Margin="0,0,8,0" 
                                 VerticalContentAlignment="Center" 
                                 Padding="8,0" 
                                 FontSize="13" 
                                 BorderBrush="#E5E0D8" 
                                 BorderThickness="1" 
                                 Text="Название"/>
                        <TextBox x:Name="NewTileUrl" 
                                 Width="160" 
                                 Height="30" 
                                 Margin="0,0,8,0" 
                                 VerticalContentAlignment="Center" 
                                 Padding="8,0" 
                                 FontSize="13" 
                                 BorderBrush="#E5E0D8" 
                                 BorderThickness="1" 
                                 Text="https://..."/>
                        <Button Content="✓" 
                                Width="28" 
                                Height="28" 
                                Background="{StaticResource AccentBrush}" 
                                Foreground="White" 
                                BorderThickness="0" 
                                Cursor="Hand" 
                                Click="BtnConfirmAddTile_Click" 
                                Margin="0,0,4,0"/>
                        <Button Content="✕" 
                                Width="28" 
                                Height="28" 
                                Background="#E5E0D8" 
                                Foreground="#4A4A4A" 
                                BorderThickness="0" 
                                Cursor="Hand" 
                                Click="BtnCancelAddTile_Click"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Контент стартовой страницы -->
            <DockPanel Margin="20,90,20,20" LastChildFill="True">
                <!-- Панель "Избранное" -->
                <Border DockPanel.Dock="Top" 
                        Height="110" 
                        Margin="0,0,0,15" 
                        Background="White" 
                        BorderBrush="#E5E0D8" 
                        BorderThickness="1" 
                        CornerRadius="16" 
                        Padding="5,8,15,8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                    </Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left"
                                   Text="📑 Избранное"
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   Foreground="#4A4A4A"
                                   VerticalAlignment="Center"
                                   Margin="0,0,20,0"
                                   Opacity="0.8"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="TilesWrapPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Строка поиска -->
                <Border DockPanel.Dock="Top" 
                        Height="65" 
                        Margin="0,0,0,20" 
                        CornerRadius="12" 
                        Padding="12" 
                        Background="White" 
                        HorizontalAlignment="Center" 
                        Width="600">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="SearchEngineComboBox" 
                                  Grid.Column="0" 
                                  Width="140" 
                                  Height="38" 
                                  FontSize="13" 
                                  VerticalContentAlignment="Center" 
                                  Margin="0,0,10,0">
                            <ComboBoxItem Content="🔍 Google" IsSelected="True"/>
                            <ComboBoxItem Content="🤖 Perplexity"/>
                            <ComboBoxItem Content="🇷🇺 Yandex"/>
                            <ComboBoxItem Content="🦆 DuckDuckGo"/>
                            <ComboBoxItem Content="🤖 Bing AI"/>
                        </ComboBox>
                        <TextBox x:Name="SearchBox" 
                                 Grid.Column="1" 
                                 Height="38" 
                                 FontSize="14" 
                                 VerticalContentAlignment="Center" 
                                 Padding="12,0" 
                                 BorderBrush="{StaticResource BorderBrush}" 
                                 BorderThickness="1" 
                                 KeyDown="SearchBox_KeyDown" 
                                 GotFocus="SearchBox_GotFocus" 
                                 LostFocus="SearchBox_LostFocus" 
                                 Text="Введите запрос..."/>
                        <Button Content="🔍" 
                                Grid.Column="2" 
                                Width="45" 
                                Height="38" 
                                Margin="10,0,0,0" 
                                Background="{StaticResource PrimaryBrush}" 
                                Foreground="White" 
                                BorderThickness="0" 
                                FontSize="18" 
                                Cursor="Hand" 
                                Click="BtnSearch_Click"/>
                    </Grid>
                </Border>

                <!-- СЕТКА ПАНЕЛЕЙ 2×2 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Блок 1: 🤖 ИИ Помощники -->
                    <Border Grid.Row="0" Grid.Column="0" Margin="15" Background="White" BorderBrush="#E5E0D8" BorderThickness="1" CornerRadius="16" Padding="12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🤖 ИИ Помощники" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       Foreground="#4A4A4A" 
                                       Margin="0,0,0,8" 
                                       HorizontalAlignment="Center" 
                                       Opacity="0.8"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200" HorizontalScrollBarVisibility="Disabled">
                                <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- 8 карточек ИИ помощников -->
                                    <Border Width="80" Height="80" Margin="4" Background="White" BorderBrush="#E5E0D8" BorderThickness="1" CornerRadius="12" Cursor="Hand" Tag="Qwen|https://chat.qwen.ai">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image Width="32" Height="32" Margin="0,0,0,4">
                                                <Image.Source>
